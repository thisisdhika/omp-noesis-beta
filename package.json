{
  "name": "@omp-noesis/extension",
  "version": "0.1.0",
  "description": "Enterprise cognitive substrate for Oh My Pi — structured beliefs, learning loops, and context discipline",
  "type": "module",
  "main": "src/index.ts",
  "omp": {
    "extensions": ["src/index.ts"]
  },
  "scripts": {
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:behavioral": "bun test tests/behavioral",
    "lint": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run --watch src/index.ts"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=15.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "oh-my-pi",
    "omp",
    "agent",
    "cognitive",
    "memory",
    "belief",
    "learning",
    "graphify"
  ],
  "author": "Dhika Putra Ardana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omp-noesis/extension"
  }
}