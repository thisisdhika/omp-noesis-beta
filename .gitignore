# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# =============================================================================
# Noesis — Tracked artifacts (explicit whitelist)
# =============================================================================
# Pattern: .omp/* ignores children, then ! patterns re-allow specific paths.
# Each directory level must be un-ignored before its children can be tracked.

.omp/*
!.omp/
!.omp/RULES.md
!.omp/config.yml
!.omp/skills/
!.omp/skills/graphify/
!.omp/skills/graphify/SKILL.md

# Noesis — generated graph artifacts (never version)
graphify-out/

# Noesis — projected vault artifacts (derived from state.json)
.obsidian/noesis/
# Test temporary directories (copies of src/ for new test runner)
tests/helpers/.test-*/


# Noesis — root-level documentation (tracked)
!Noesis Index.md

# Lockfile (Bun-native; npm lockfile not needed)
package-lock.json
